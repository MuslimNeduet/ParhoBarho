# Backend env (DO NOT commit real secrets)
PORT=5000
FRONTEND_ORIGIN=http://localhost:3000

# Admin page auth token (set this to a long random string in production)
ADMIN_TOKEN=change-me

# Khabarnama scheduler (every 15 minutes by default)
NEWS_CRON=*/15 * * * *
# Optional: point to file where you manage custom source URLs
NEWS_SOURCES_FILE=./newsSources.config.json
# Optional: override by env JSON object with 3 sections (generic, universities, competitive)
# NEWS_SOURCES_JSON={"generic":[{"key":"hec","name":"HEC Pakistan","url":"https://www.hec.gov.pk/english/news/Pages/default.aspx"}],"universities":[],"competitive":[]}

# Optional MongoDB for persistent knowledge storage (recommended for hosting)
MONGODB_URI=

# Gemini config
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-pro-latest

